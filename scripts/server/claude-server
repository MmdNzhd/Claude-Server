#!/bin/bash
# claude-server - Claude Code Server management CLI
# Usage: sudo bash scripts/server/claude-server install
#        claude-server <command> [options]

VERSION="1.0.0"
SELF="$(readlink -f "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"

# Find commands dir: alongside this script (repo mode) or installed location
if [ -d "$SCRIPT_DIR/commands" ]; then
    COMMANDS_DIR="$SCRIPT_DIR/commands"
elif [ -d /usr/local/lib/claude-server ]; then
    COMMANDS_DIR=/usr/local/lib/claude-server
else
    COMMANDS_DIR=""
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo ""
    echo -e "${BOLD}claude-server${NC} v${VERSION} — Claude Code Server management"
    echo ""
    echo "Usage: claude-server <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install              full server install (requires root)"
    echo "  add-user <name>      add a new developer user"
    echo "  verify               check all components"
    echo "  status               active sessions + usage stats"
    echo ""
    echo "Options:"
    echo "  --help, -h           show this help"
    echo "  --version, -v        show version"
    echo ""
    echo "Examples:"
    echo "  sudo claude-server install"
    echo "  sudo claude-server add-user amir"
    echo "  claude-server verify"
    echo "  claude-server status"
    echo ""
}

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
    install|add-user|verify|status)
        if [ -z "$COMMANDS_DIR" ]; then
            echo -e "${RED}Error:${NC} commands directory not found." >&2
            echo "Run from repo: bash scripts/server/claude-server install" >&2
            echo "Or reinstall: sudo claude-server install" >&2
            exit 1
        fi
        SCRIPT="$COMMANDS_DIR/${CMD}.sh"
        if [ ! -f "$SCRIPT" ]; then
            echo -e "${RED}Error:${NC} command script not found: $SCRIPT" >&2
            exit 1
        fi
        exec bash "$SCRIPT" "$@"
        ;;
    --version|-v)
        echo "claude-server v${VERSION}"
        ;;
    --help|-h|"")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command:${NC} $CMD" >&2
        usage >&2
        exit 1
        ;;
esac
